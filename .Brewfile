# Damien's Brewfile

# Brew Taps
tap "homebrew/bundle"
tap "homebrew/cask"
tap "homebrew/cask-fonts"
tap "homebrew/core"
tap "homebrew/services"

# Brew CLI apps
brew "python@3.9"
brew "ansible@2.9", link: true
brew "coreutils"
brew "go"
brew "kubernetes-cli"
brew "mas"
brew "oath-toolkit"
brew "openjdk"
brew "openshift-cli"
brew "podman"

# Brew Font Casks
cask "font-hack-nerd-font"
cask "font-inconsolata-for-powerline"
cask "font-menlo-for-powerline"

# Brew App Casks
cask "iterm2"
cask "minecraft"
cask "obs"
cask "prusaslicer"
cask "setapp"
cask "superduper"
cask "vagrant"
cask "virtualbox"
cask "visual-studio-code"
cask "vnc-viewer"

# Mac App Store Apps
mas "BetterSnapTool", id: 417375580
mas "HotKey", id: 975890633
mas "iMovie", id: 408981434
mas "Save to Pocket", id: 1477385213
#mas "Xcode", id: 497799835  # takes far too long
